system:
    instructions: "You are a customer service assistant for Coral Cloud Resorts, a hotel that offers experiences to its customers."

    messages:
        welcome: |
            Hi, I'm the Coral Cloud customer service assistant. How can I help you?
        error: "Sorry, it looks like something has gone wrong."

config:
    agent_label: "Customer Service Agent"
    developer_name: "Customer_Service_Agent"
    description: "Deliver personalized customer interactions and assist with customer inquiries and requests."
    default_agent_user: "customer_service_agent@00dws00000n2qjd1131185311.ext"

language:
    default_locale: "en_US"
    additional_locales: "en_GB"
    all_additional_locales: False

variables:
    isVerifyingIdentity: mutable boolean = False
        description: "Whether the agent is verifying the user identity or not"
    actionOutputMessage: mutable string = ""
        description: "Holds the output message of an action"
    recentlyViewedSessions: mutable string = ""
        description: "Holds the recently viewed sessions for the customer"
    isVerifiedCustomer: mutable boolean = False
        description: "Whether the user is a verified customer or not"
        visibility: "External"
    verifiedCustomerId: mutable string = ""
        description: "The contact ID for the current user when they are a verified customer"
        visibility: "External"

start_agent agent_router:
    label: "Agent Router"

    description: "Welcome the user and determine the appropriate topic based on user input"

    before_reasoning:
        if @variables.isVerifyingIdentity == True:
            transition to @subagent.identify_customer

    reasoning:
        instructions: ->
            | Select the best tool to call based on conversation history and user's intent.

        actions:
            transition_to_identify_customer: @utils.transition to @subagent.identify_customer
                description: "Call this to identify a customer"
                available when @variables.isVerifiedCustomer == False

            transition_to_browse_experiences: @utils.transition to @subagent.browse_experiences
                description: "Call this when the user wants to browse experiences"

            transition_to_manage_bookings: @utils.transition to @subagent.manage_bookings
                description: "Call this when the user wants to manage their experience bookings or suggest sessions of interest"
                available when @variables.isVerifiedCustomer == True


subagent identify_customer:
    label: "Identify Customer"
    description: "Identifies the customer"
    before_reasoning:
        set @variables.isVerifyingIdentity = True
    reasoning:
        instructions: ->
            |Ask the user for their email address then call {!@actions.verifyCustomer}.
        actions:
            verifyCustomer: @actions.identifyCustomerByEmail
                with emailAddress = ...
                set @variables.isVerifiedCustomer = @outputs.isVerifiedCustomer
                set @variables.verifiedCustomerId = @outputs.verifiedCustomerId
                set @variables.actionOutputMessage = @outputs.outputMessage
    after_reasoning:
        if @variables.isVerifiedCustomer == True:
            set @variables.isVerifyingIdentity = False
            transition to @subagent.manage_bookings

    actions:
        identifyCustomerByEmail:
            description: "Confirms the identity of a customer (Contact) thanks to their email"
            inputs:
                emailAddress: string
                    description: "Stores the email address provided by the customer."
                    label: "Email Address"
                    is_required: True
                    is_user_input: False
            outputs:
                isVerifiedCustomer: boolean
                    label: "Is Verified Customer"
                verifiedCustomerId: string
                    label: "Verified Customer ID"
                outputMessage: string
                    label: "Output Message"
            target: "flow://Identify_Customer_By_Email"
            label: "Identify Customer By Email"
            require_user_confirmation: False
            include_in_progress_indicator: True
            progress_indicator_message: "Identifying customer..."

subagent browse_experiences:
    label: "Browse Experiences"
    description: "Handles customer requests to view experiences"
    reasoning:
        instructions: ->
            | Your job is to help users discover available experiences.
            if @variables.isVerifiedCustomer == True:
                | If the user asks for recommendations or sessions of interest or wants to manage their bookings,
                | call {!@actions.transition_to_manage_bookings}.
            else:
                | If the user asks for recommendations or sessions of interest or wants to manage their bookings,
                | ask them to identify themselves first by calling {!@actions.transition_to_identify_customer}.
            | If the user asks to see experiences types, call {!@actions.listExperienceTypes}
            | If the user asks to see experiences for a specific type, call {!@actions.listExperiencesFromType} with that type.
            | If the user asks for sessions for a specific experience, call {!@actions.listSessionsFromExperience} with the experience name.
        actions:
            listExperienceTypes: @actions.listExperienceTypes
                with dummyInput = ""
            listExperiencesFromType: @actions.listExperiencesFromType
                with experienceType = ...
            listSessionsFromExperience: @actions.listSessionsFromExperience
                with experienceName = ...
                set @variables.recentlyViewedSessions = @outputs.sessions
            transition_to_identify_customer: @utils.transition to @subagent.identify_customer
                description: "Call this to identify a customer"
                available when @variables.isVerifiedCustomer == False
            transition_to_manage_bookings: @utils.transition to @subagent.manage_bookings
                description: "Call this when the user wants to manage their experience bookings or suggest sessions of interest"
                available when @variables.isVerifiedCustomer == True

    actions:
        listExperienceTypes:
            description: "Returns the list of available experience types."
            inputs:
                dummyInput: string
                    description: "Unused input required by the invocable Apex action."
                    label: "Dummy Input"
                    is_required: False
            outputs:
                experienceTypes: string
                    description: "The list of available experience types, serialized as a JSON string."
                    label: "Experience Types"
            target: "apex://ListExperienceTypes"
            label: "List Experience Types"
            require_user_confirmation: False
            include_in_progress_indicator: True
        listExperiencesFromType:
            description: "Returns the list of experiences for the specified type."
            inputs:
                experienceType: string
                    description: "The experience type selected by the user."
                    label: "Experience Type"
                    is_required: True
            outputs:
                experiences: string
                    description: "The list of experiences that match the selected type, serialized as a JSON string."
                    label: "Experiences"
            target: "apex://ListExperiencesFromType"
            label: "List Experiences from Type"
            require_user_confirmation: False
            include_in_progress_indicator: True
        listSessionsFromExperience:
            description: "Returns the list of sessions for the specified experience."
            inputs:
                experienceName: string
                    description: "The experience name selected by the user."
                    label: "Experience Name"
                    is_required: True
            outputs:
                sessions: string
                    description: "The list of sessions for the selected experience, serialized as a JSON string."
                    label: "Sessions"
            target: "apex://ListSessionsFromExperience"
            label: "List Sessions from Experience"
            require_user_confirmation: False
            include_in_progress_indicator: True

subagent manage_bookings:
    label: "Manage Bookings"

    description: "Handles customer requests to manage their experience bookings or suggest sessions of interest"

    reasoning:
        instructions: ->
            | Your job is to help customers manage their experience bookings and suggest sessions of interest based on their preferences.
            | These are the sessions recently viewed by the customer: {!@variables.recentlyViewedSessions}
            | If the user asks for recommendations or sessions of interest, call {!@actions.getPersonalizedSchedule}.
            | If the user asks to book a session, call {!@actions.bookSession} with the session ID extracted from the recently viewed sessions.
            | If the user asks general questions about experiences, call {!@actions.transition_to_browse_experiences}.
        actions:
            getPersonalizedSchedule: @actions.getPersonalizedSchedule
                with contactId = @variables.verifiedCustomerId
                set @variables.recentlyViewedSessions=@outputs.sessions

            bookSession: @actions.bookSession
                with contactId = @variables.verifiedCustomerId
                with sessionId = ...
                with numberOfGuests = 1

            transition_to_browse_experiences: @utils.transition to @subagent.browse_experiences
                description: "Call this when the user asks general questions about experiences"
                available when @variables.isVerifiedCustomer == True
    
    actions:
        getPersonalizedSchedule:
            description: "Returns the personalized schedule for the customer."
            inputs:
                contactId: string
                    description: "The contact ID of the customer."
                    label: "Contact ID"
                    is_required: True
            outputs:
                sessions: string
                    description: "The sessions for the customer, serialized as a JSON string."
                    label: "Sessions"
            target: "apex://PersonalizedGuestExperiences"
            label: "Get Sessions of Interest for Today"
            require_user_confirmation: False
            include_in_progress_indicator: True
            

        bookSession:
            description: "Books a session for the customer."
            inputs:
                contactId: string
                    description: "The contact ID of the customer."
                    label: "Contact ID"
                    is_required: True
                sessionId: string
                    description: "The session ID to book."
                    label: "Session ID"
                    is_required: True
                numberOfGuests: integer
                    description: "The number of guests to book the session for."
                    label: "Number of Guests"
                    is_required: True
            outputs:
                createdBooking: string
                    description: "The created booking, serialized as a JSON string."
                    label: "Created Booking"
            target: "apex://CreateBooking"
            label: "Book Session"
            require_user_confirmation: False
            include_in_progress_indicator: True

